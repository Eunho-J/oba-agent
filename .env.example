# Agent gateway
PORT=8787
PUBLIC_APP_URL=http://localhost:8787
OBA_WORKSPACE_ROOT=

# OBA v1 main provider testbed.
# Run `npx codex-as-api` after `codex login`; OBA only calls the local HTTP API.
OBA_PROVIDER_BASE_URL=http://127.0.0.1:18080/v1
OBA_PROVIDER_HEALTH_URL=http://127.0.0.1:18080/health
OBA_PROVIDER_API_KEY=unused
OBA_PROVIDER_MODEL=gpt-5.5
OBA_PROVIDER_NAME=codex-as-api
OBA_MCP_SERVERS_JSON={}

# Run gated provider integration tests only when codex-as-api is running locally.
OBA_RUN_CODEX_AS_API_TESTS=0

# Local workflow runtime
OBA_LOCAL_WORKFLOW_ENABLED=1
OBA_LOCAL_WORKFLOW_REGISTRY=.oppa/registry
OBA_LOCAL_WORKFLOW_PATH=.oppa/workflows

# ApiFuse
APIFUSE_BASE_URL=https://api.apifuse.com
APIFUSE_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3.5-flash

# Local LM Studio OpenAI-compatible runtime for EXAONE (MVP: no tool-calling).
OBA_LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
OBA_LLM_API_KEY=lm-studio
OBA_LLM_MODEL=exaone-4.0-1.2b
OBA_LLM_REQUEST_TIMEOUT_MS=15000
OBA_LLM_MAX_TOKENS_CAP=1024
OBA_LLM_TEMPERATURE_CAP=1
OBA_LLM_MODEL_ALLOWLIST=exaone-4.0-1.2b

# Backward-compatible EXAONE aliases
EXAONE_BASE_URL=http://127.0.0.1:1234/v1
EXAONE_API_KEY=lm-studio
EXAONE_MODEL=exaone-4.0-1.2b
EXAONE_EXPRESSION_PROMPT_PATH=prompts/exaone-expression.md
